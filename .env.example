# N05 Tyre & MOT - Environment Variables
# Copy to .env and fill in your values

PORT=3001

# Check Car Details API (https://api.checkcardetails.co.uk/auth/register)
CHECK_CAR_DETAILS_API_KEY=your_api_key_here
# CHECK_CAR_DETAILS_BASE=https://api.checkcardetails.co.uk

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Telegram notifications (send booking alerts to admin)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# SMTP for customer confirmation emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_password
SMTP_FROM="N05 Tyre & MOT" <noreply@no5mot.co.uk>
